--Delete trigger
CREATE TRIGGER raamatKustutamine
ON raamatud
FOR DELETE
AS
INSERT INTO logi(kuupaev, kasutaja, toiming, andmed)
SELECT
GETDATE(),
SYSTEM_USER,
'raamat kustutatud',
CONCAT('pealkiri: ', deleted.pealkiri, ', autor: ', deleted.autor, ', zanr: ', deleted.zanr, ', hind: ', deleted.hind)
FROM deleted;

-- Delete kontroll 
DELETE FROM raamatud WHERE id = 2;
SELECT * FROM logi;
SELECT * FROM raamatud;

--Update trigger

CREATE TRIGGER raamatUuendamine
ON raamatud
FOR UPDATE
AS
INSERT INTO logi(kuupaev, kasutaja, toiming, andmed)
SELECT
GETDATE(),
SYSTEM_USER,
'raamat muudetud',
CONCAT('VANAD: ', deleted.pealkiri, ', ', deleted.autor, ', ', deleted.zanr, ', ', deleted.hind,  ' UUED: ', inserted.pealkiri, ', ', inserted.autor, ', ', inserted.zanr, ', ', inserted.hind )
FROM deleted INNER JOIN inserted
ON deleted.id = inserted.id;

--update kontroll
UPDATE raamatud SET pealkiri='sipsik123'
WHERE pealkiri='sipsik';

SELECT * FROM logi;
SELECT * FROM raamatud;

--insert + delete trigger

CREATE TRIGGER raamatLisaKustuta
ON raamatud
FOR INSERT, DELETE
AS
BEGIN
SET NOCOUNT ON;
	INSERT INTO logi(kuupaev, kasutaja, toiming, andmed)

	SELECT
	GETDATE(),
	SYSTEM_USER,
	'on tehtud INSERT käsk',
	CONCAT('pealkiri: ', inserted.pealkiri, ', autor: ', inserted.autor, ', zanr: ', inserted.zanr, ', hind: ', inserted.hind)
	FROM inserted

	UNION ALL

	SELECT
	GETDATE(),
	SYSTEM_USER,
	'on tehtud DELETE käsk',
	CONCAT('pealkiri: ', deleted.pealkiri, ', autor: ', deleted.autor, ', zanr: ', deleted.zanr,', hind: ', deleted.hind)
	FROM deleted;
END;

DISABLE TRIGGER raamatLisamine ON Raamatud;

DISABLE TRIGGER raamatKustutamine ON Raamatud;


