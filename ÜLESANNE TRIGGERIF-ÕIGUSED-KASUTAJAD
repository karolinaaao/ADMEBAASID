CREATE DATABASE karolinaTrigger;
use karolinaTrigger;

--tabel
CREATE TABLE raamatud(
id INT PRIMARY KEY IDENTITY(1,1),
pealkiri VARCHAR(100) NOT NULL,
autor VARCHAR(100) NOT NULL,
zanr VARCHAR(50),
hind money
)

