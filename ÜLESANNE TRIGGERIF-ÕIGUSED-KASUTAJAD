SELECT * FROM raamatud;

--logi tabel
CREATE TABLE logi(
id INT PRIMARY KEY IDENTITY(1,1),
kuupaev DATETIME,
kasutaja VARCHAR(30),
toiming VARCHAR(100),
andmed TEXT
)

SELECT * FROM logi;

--TRIGGERID
--INSERT

CREATE TRIGGER raamatLisamine
ON raamatud
FOR INSERT
AS
INSERT INTO logi(kuupaev, kasutaja, toiming, andmed)
SELECT
GETDATE(),
SYSTEM_USER,
'uus raamat lisatud',
CONCAT('pealkiri: ', inserted.pealkiri, ', autor: ', inserted.autor, ', zanr: ', inserted.zanr, ', hind: ', inserted.hind)
FROM inserted;

