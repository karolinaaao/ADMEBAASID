--Kommentaari kustutamine ID järgi
CREATE PROCEDURE kustutaKommentaar
    @id INT
AS
BEGIN
    DELETE FROM kommentaar
    WHERE kommentaar_id = @id;
END;

EXEC kustutaKommentaar 1;
