--protseduurid andmete kiireks lisamiseks.Kasutaja Lisamise protseduur

CREATE PROCEDURE lisaKasutaja
    @eesnimi VARCHAR(50),
    @perenimi VARCHAR(50),
    @email VARCHAR(150)
AS
BEGIN
    INSERT INTO kasutaja(eesnimi, perenimi, email)
    VALUES(@eesnimi, @perenimi, @email);
END;

EXEC lisaKasutaja 'Mari', 'Lepp', 'mari@gmail.com';

--Retsepti Lisamise protseduur

CREATE PROCEDURE lisaRetsept
    @nimi VARCHAR(100),
    @kirjeldus VARCHAR(200),
    @juhend VARCHAR(500),
    @kp DATE,
    @kasutaja_id INT,
    @kategooria_id INT
AS
BEGIN
    INSERT INTO retsept
    (retsepti_nimi, kirjeldus, juhend, sisestatud_kp,
     kasutaja_id, kategooria_id)

    VALUES
    (@nimi, @kirjeldus, @juhend, @kp,
     @kasutaja_id, @kategooria_id);
END;


--TABELI MUUTMISE PROTSEDUUR

CREATE PROCEDURE muudaTabel
    @tabeliNimi VARCHAR(100),
    @valjaNimi VARCHAR(100),
    @andmeTyyp VARCHAR(100)
AS
BEGIN
    DECLARE @sql NVARCHAR(MAX);

    SET @sql =
    'ALTER TABLE ' + @tabeliNimi +
    ' ADD ' + @valjaNimi + ' ' + @andmeTyyp;

    EXEC sp_executesql @sql;
END;

EXEC muudaTabel
'kasutaja',
'telefon',
'VARCHAR(20)';

--SELECT - PARAMEETRID SEOTUD TABELITEST
SELECT
    kasutaja.eesnimi,
    kasutaja.perenimi,
    retsept.retsepti_nimi
FROM kasutaja
INNER JOIN retsept
ON kasutaja.kasutaja_id = retsept.kasutaja_id;
--Retsept ja kategooria
SELECT
    retsept.retsepti_nimi,
    kategooria.kategooria_nimi
FROM retsept
INNER JOIN kategooria
ON retsept.kategooria_id = kategooria.kategooria_id;
--Retsept ja koostisosad
SELECT
    retsept.retsepti_nimi,
    toiduaine.toiduaine_nimi,
    koostis.kogus,
    yhik.yhik_nimi
FROM koostis
INNER JOIN retsept
ON koostis.retsept_retsept_id = retsept.retsept_id

INNER JOIN toiduaine
ON koostis.toiduaine_id = toiduaine.toiduaine_id

INNER JOIN yhik
ON koostis.yhik_id = yhik.yhik_id;

--Kommentaarid retseptide kohta
SELECT
    retsept.retsepti_nimi,
    kommentaar.kommentaar_tekst,
    kommentaar.kommentaar_kp
FROM kommentaar
INNER JOIN retsept
ON kommentaar.retsept_id = retsept.retsept_id;
--Protseduurid kommentaarile
CREATE PROCEDURE lisaKommentaar
    @tekst VARCHAR(300),
    @kp DATE,
    @retsept_id INT
AS
BEGIN
    INSERT INTO kommentaar
    (kommentaar_tekst, kommentaar_kp, retsept_id)

    VALUES
    (@tekst, @kp, @retsept_id);
END;

